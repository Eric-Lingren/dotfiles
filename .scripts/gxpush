#!/usr/bin/env bash
# gxpush — preview-and-confirm push with flags

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/gx-lib.sh"

gx_load_policy

# Always operate from repo root so git ls-files finds all files regardless of CWD
cd "$(git rev-parse --show-toplevel)"

MODE_ALL=false
MODE_PICK=false
MODE_PR=false
MODE_PUSH_ONLY=false
MODE_AUTO=false

for arg in "$@"; do
  case "$arg" in
    --all)        MODE_ALL=true ;;
    --pick)       MODE_PICK=true ;;
    --pr)         MODE_PR=true ;;
    --push-only)  MODE_PUSH_ONLY=true ;;
    --auto)       MODE_AUTO=true ;;
  esac
done

BRANCH=$(git rev-parse --abbrev-ref HEAD)
BASE="${GX_BASE_BRANCH:-main}"

# Newline-separated exclude patterns from registry
GX_EXCLUDE_PATS=$(gx_exclude_patterns)

# Determine which files will be staged
compute_staged_list() {
  git diff --cached --name-only
}

compute_will_add() {
  { git diff --name-only --diff-filter=ACMRT; git ls-files --others --exclude-standard; } | sort -u
}

compute_will_delete() {
  git diff --name-only --diff-filter=D | sort -u
}

# Returns newline-separated list of files matching any exclude pattern
_matches_exclude() {
  local f="$1"
  while IFS= read -r pat; do
    [[ -z "$pat" ]] && continue
    if [[ "$f" == "$pat"* || "$f" == *"/$pat"* ]]; then
      return 0
    fi
  done <<< "$GX_EXCLUDE_PATS"
  return 1
}

compute_excluded() {
  local all_files
  all_files=$({ git diff --name-only; git ls-files --others --exclude-standard; } | sort -u)
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    _matches_exclude "$f" && echo "$f"
  done <<< "$all_files"
}

# Secret scanning: look for common secret patterns in staged + will-add files
secret_scan() {
  local -a files=("$@")
  local -a hits=()
  local patterns=(
    'AKIA[0-9A-Z]{16}'
    'ghp_[A-Za-z0-9]{36}'
    'sk-[A-Za-z0-9]{20,}'
    'token\s*=\s*["\x27][A-Za-z0-9\-_]{20,}'
    'password\s*=\s*["\x27][^\s"\x27]{8,}'
    'secret\s*=\s*["\x27][A-Za-z0-9\-_]{16,}'
    '\.env$'
    'id_rsa'
    'id_ed25519'
  )
  for f in "${files[@]}"; do
    [[ -f "$f" ]] || continue
    # Skip shell scripts — patterns match their own source, not real secrets
    [[ "$f" == *.sh || "$f" == .scripts/* || "$f" == */.scripts/* ]] && continue
    for pat in "${patterns[@]}"; do
      if grep -qE "$pat" "$f" 2>/dev/null; then
        hits+=("$f")
        break
      fi
    done
    # Flag .env files by name
    if [[ "$f" == *.env || "$f" == .env || "$f" == */.env ]]; then
      hits+=("$f")
    fi
  done
  printf '%s\n' "${hits[@]}" | sort -u
}

# --- Compute preview data ---
STAGED=$(compute_staged_list)
WILL_ADD=$(compute_will_add)
WILL_DELETE=$(compute_will_delete)
EXCLUDED=$(compute_excluded)

# Compute UNSTAGED: modified tracked files not being committed and not in will-add
ALL_MODIFIED=$(git diff --name-only)
UNSTAGED=""
while IFS= read -r f; do
  [[ -z "$f" ]] && continue
  if ! echo "$WILL_ADD" | grep -qxF "$f" && ! echo "$EXCLUDED" | grep -qxF "$f"; then
    UNSTAGED+="$f"$'\n'
  fi
done <<< "$ALL_MODIFIED"

# Filter excluded from will-add
WILL_ADD_FILTERED=""
while IFS= read -r f; do
  [[ -z "$f" ]] && continue
  if ! echo "$EXCLUDED" | grep -qxF "$f"; then
    WILL_ADD_FILTERED+="$f"$'\n'
  fi
done <<< "$WILL_ADD"

# Secret scan on will-add + staged
SECRET_FILES=""
while IFS= read -r f; do
  [[ -z "$f" ]] && continue
  secret_scan "$f"
done <<< "$WILL_ADD_FILTERED"$'\n'"$STAGED" | sort -u | while IFS= read -r f; do
  SECRET_FILES+="$f"$'\n'
done

# --- Print preview manifest ---
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  gxpush preview — branch: $BRANCH"
if $MODE_ALL; then echo "  mode: --all (blast-radius)"; fi
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

echo "STAGED (already in index):"
if [[ -n "$STAGED" ]]; then
  while IFS= read -r f; do [[ -n "$f" ]] && echo "  $f"; done <<< "$STAGED"
else
  echo "  (none)"
fi
echo ""

echo "WILL ADD / MODIFY:"
if [[ -n "$WILL_ADD_FILTERED" ]]; then
  while IFS= read -r f; do [[ -n "$f" ]] && echo "  $f"; done <<< "$WILL_ADD_FILTERED"
else
  echo "  (none)"
fi
echo ""

echo "WILL DELETE:"
if [[ -n "$WILL_DELETE" ]]; then
  while IFS= read -r f; do [[ -n "$f" ]] && echo "  $f"; done <<< "$WILL_DELETE"
else
  echo "  (none)"
fi
echo ""

echo "EXCLUDED (policy — will not be staged):"
if [[ -n "$EXCLUDED" ]]; then
  while IFS= read -r f; do [[ -n "$f" ]] && echo "  $f"; done <<< "$EXCLUDED"
else
  echo "  (none)"
fi
echo ""

echo "SECRETS (potential — review before pushing):"
SECRETS=$( (while IFS= read -r f; do [[ -n "$f" ]] && secret_scan "$f"; done <<< "$WILL_ADD_FILTERED"$'\n'"$STAGED") | sort -u )
if [[ -n "$SECRETS" ]]; then
  while IFS= read -r f; do [[ -n "$f" ]] && echo "  !! $f"; done <<< "$SECRETS"
else
  echo "  (none)"
fi
echo ""

if [[ -n "$UNSTAGED" ]]; then
  echo "UNSTAGED (modified but not being committed):"
  while IFS= read -r f; do [[ -n "$f" ]] && echo "  $f"; done <<< "$UNSTAGED"
  echo ""
fi

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# Non-interactive guard: require --auto when stdin is not a terminal
if [ ! -t 0 ] && ! $MODE_AUTO; then
  echo ""
  echo "ERROR: non-interactive terminal detected. Pass --auto to proceed without prompts."
  echo "Aborting."
  exit 1
fi

# In push-only mode, skip staging/commit gate
if ! $MODE_PUSH_ONLY; then
  # Hard stop if nothing to commit
  if [[ -z "$STAGED" && -z "$WILL_ADD_FILTERED" ]]; then
    echo "Nothing to commit. Aborting."
    exit 0
  fi
fi

# Confirm
if [[ "$BRANCH" == "$BASE" ]]; then
  echo -e "\033[1;33m⚠️  WARNING: pushing directly to $BASE\033[0m"
fi
if ! $MODE_AUTO; then
  printf "Proceed? [Y/n] "
  read -r CONFIRM
  if [[ "$CONFIRM" == "n" || "$CONFIRM" == "N" ]]; then
    echo "Aborted."
    exit 0
  fi
fi

# --- Execute ---

# Apply excludes: temporarily move excluded files out of staging
unstage_excluded() {
  while IFS= read -r f; do
    [[ -n "$f" ]] && git reset HEAD -- "$f" 2>/dev/null
  done <<< "$EXCLUDED"
}

if ! $MODE_PUSH_ONLY; then
  if $MODE_PICK; then
    git add -p
  else
    git add -A
    unstage_excluded
  fi

  echo "Generating commit message..."
  COMMIT_MSG=$("$SCRIPT_DIR/pr-commit" --stdout 2>/dev/null)

  if [[ -z "$COMMIT_MSG" ]]; then
    COMMIT_MSG="update files"
  fi

  if ! $MODE_AUTO; then
    if [[ "${BASH_VERSINFO[0]}" -ge 4 ]]; then
      read -e -r -p "Commit message (edit or enter to accept): " -i "$COMMIT_MSG" OVERRIDE
    else
      printf "Commit message (enter to accept, or type replacement):\n  %s\n> " "$COMMIT_MSG"
      read -r OVERRIDE
    fi
    if [[ -n "$OVERRIDE" ]]; then
      COMMIT_MSG="$OVERRIDE"
    fi
  fi

  git commit -m "$COMMIT_MSG"
  if [[ $? -ne 0 ]]; then
    echo "Commit failed. Aborting push."
    exit 1
  fi
fi

git push -u origin HEAD
if [[ $? -ne 0 ]]; then
  echo "Push failed."
  exit 1
fi

if $MODE_PR; then
  echo ""
  echo "Creating PR..."
  PR_BODY=$("$SCRIPT_DIR/pr-desc" --stdout)
  BRANCH_SLUG=$(echo "$BRANCH" | tr '/' '-')
  if [[ "${GX_PR_DRAFT:-false}" == "true" ]]; then
    echo "  [draft — repo policy requires draft PRs for this repo]"
    gh pr create --title "$BRANCH_SLUG" --body "$PR_BODY" --draft
  else
    gh pr create --title "$BRANCH_SLUG" --body "$PR_BODY"
  fi
fi

echo "Done."
