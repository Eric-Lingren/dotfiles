{
  "_doc": "Single source of truth for per-skill and per-agent model+effort tiering. Edit this, then run scripts/sync-model-tiers.py --apply (or just commit; the pre-commit hook applies it). Full docs: resources/model-tiers.md",
  "tiers": {
    "T1": { "model": "haiku",  "effort": "low",    "_meaning": "Lookup. No reasoning. File search, status, how-to." },
    "T2": { "model": "sonnet", "effort": "medium", "_meaning": "Mechanical. Narrow, well-defined scope." },
    "T3": { "model": "sonnet", "effort": "xhigh",  "_meaning": "Standard build. Context-aware. THIS IS THE SESSION DEFAULT." },
    "T4": { "model": "opus",   "effort": "xhigh",  "_meaning": "Deep reasoning. Architecture, complex debug, planning." }
  },
  "default": "T3",
  "skills": {
    "how-to": "T1",
    "find-work": "T1",
    "tasks-to-linear": "T2",
    "run-task-followups": "T2",
    "cc-usage-analytics": "T2",
    "run-tasks": "T3",
    "tdd": "T3",
    "improve-component": "T3",
    "code-review": "T3",
    "to-e2e-tasks": "T3",
    "prototype": "T3",
    "tldr-tech": "T3",
    "improve-skill": "T3",
    "to-prd-html": "T3",
    "to-seed": "T3",
    "to-tasks": "T3",
    "grill-me": "T4",
    "grill-with-docs": "T4",
    "debug": "T4",
    "improve-codebase-architecture": "T4",
    "fact-check": "T2",
    "register-skill": "T2",
    "handoff": "T2",
    "clean-scaffolding": "T1"
  },
  "agents": {
    "fact-checker": "T3",
    "architecture-auditor": "T3",
    "browser-checker": "T3",
    "context-loader": "T1",
    "lint-runner": "T1",
    "test-runner": "T1",
    "e2e-runner": "T1"
  },
  "delegate": [
    "run-tasks",
    "improve-component",
    "code-review",
    "to-e2e-tasks",
    "debug",
    "improve-codebase-architecture"
  ]
}
