{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "seed-schema",
  "title": "Seed File",
  "description": "Canonical shape for seed JSON files written by to-seed and consumed by to-tasks and to-prd-html.",
  "type": "object",
  "required": [
    "schema_version",
    "source",
    "title",
    "slug",
    "created",
    "summary",
    "decisions",
    "open_threads",
    "next_action"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2",
      "description": "Schema version. Must be '2'."
    },
    "source": {
      "type": "string",
      "description": "Origin of this record: 'to-seed', 'to-prd-html', or 'manual'."
    },
    "title": {
      "type": "string",
      "description": "Human-readable PRD title."
    },
    "slug": {
      "type": "string",
      "description": "Kebab-case slug derived from the title, max ~40 chars."
    },
    "created": {
      "type": "string",
      "description": "ISO 8601 timestamp when this record was created."
    },
    "summary": {
      "type": "string",
      "description": "One-paragraph plain-text summary of the problem and solution."
    },
    "decisions": {
      "type": "array",
      "description": "Resolved decisions from the session. Each entry is a plain-text string.",
      "items": { "type": "string" }
    },
    "open_threads": {
      "type": "array",
      "description": "Unresolved questions or threads that need follow-up.",
      "items": { "type": "string" }
    },
    "next_action": {
      "type": "string",
      "description": "The single most important next step after this record is written."
    },
    "problem_statement": {
      "type": "string",
      "description": "The problem in plain text."
    },
    "solution": {
      "type": "string",
      "description": "The solution in plain text."
    },
    "evidence": {
      "type": "string",
      "description": "One or two sentences: the data, complaints, or research that motivated this."
    },
    "success_metrics": {
      "type": "array",
      "items": { "type": "string" }
    },
    "user_stories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["actor", "feature", "benefit"],
        "additionalProperties": false,
        "properties": {
          "actor": { "type": "string" },
          "feature": { "type": "string" },
          "benefit": { "type": "string" }
        }
      }
    },
    "implementation_decisions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "testing_decisions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "out_of_scope": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risks_and_tradeoffs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "further_notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
