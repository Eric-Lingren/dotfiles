{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude-code-shared/hooks/block-destructive-git.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude-code-shared/hooks/block-destructive-sql.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude-code-shared/hooks/block-var-keyword.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude-code-shared/hooks/block-destructive-sed.sh\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'STYLE RULE (hard): Never use em dashes (—). Write shorter sentences. Use periods to end thoughts. Use commas for natural breaks. No long, run-on, or disjointed sentences.'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude-code-shared/hooks/test-hook.sh\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.claude-code-shared/scripts/context-bar.sh\""
  },
  "enabledPlugins": {
    "caveman@caveman": true,
    "chrome-devtools-mcp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "chrome-devtools-plugins": {
      "source": {
        "source": "github",
        "repo": "ChromeDevTools/chrome-devtools-mcp"
      }
    }
  },
  "attribution": {
    "commit": "",
    "pr": ""
  }
}
