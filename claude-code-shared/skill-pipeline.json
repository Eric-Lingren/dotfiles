{
  "_comment": "Workflow DAG for the shared skill pipeline. Consumed by inject-learning-tail.py to bake each skill's closing next-step suggestion. Shape: skills[slug].next is an array of {skill, when} edges. Terminal skills have next: []. The injector validates that every slug in 'next' exists as a directory under claude-code-shared/skills/.",
  "skills": {
    "grill-me": {
      "next": [
        {"skill": "to-seed", "when": "decisions are crisp and ready to capture"}
      ]
    },
    "grill-with-docs": {
      "next": [
        {"skill": "to-seed", "when": "decisions are crisp and ready to capture"}
      ]
    },
    "to-seed": {
      "next": [
        {"skill": "to-tasks", "when": "ready to implement without a formal PRD"},
        {"skill": "to-prd-html", "when": "want a richer PRD before tasking"},
        {"skill": "prototype", "when": "exploring the idea first"}
      ]
    },
    "to-prd-html": {
      "next": [
        {"skill": "to-tasks", "when": "PRD is approved and ready to break into tasks"}
      ]
    },
    "to-tasks": {
      "next": [
        {"skill": "run-tasks", "when": "tasks are ready to execute"}
      ]
    },
    "run-tasks": {
      "next": [
        {"skill": "to-e2e-tasks", "when": "want e2e coverage for the completed changes"}
      ]
    },
    "to-e2e-tasks": {
      "next": []
    },
    "prototype": {
