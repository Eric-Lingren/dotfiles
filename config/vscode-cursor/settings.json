{
    "workbench.colorTheme": "Bearded Theme Arc Reversed",
    "workbench.preferredDarkColorTheme": "Dracula At Night",
    "workbench.preferredLightColorTheme": "Light Modern",
    "workbench.preferredHighContrastLightColorTheme": "Bearded Theme Stained Purple",
    "workbench.editorAssociations": {
        "*.ipynb": "jupyter-notebook"
    },
    "workbench.editor.enablePreview": false,
    "workbench.editor.titleScrollbarSizing": "large",
    "workbench.editor.wrapTabs": true,
    "workbench.settings.editor": "json",
    "workbench.settings.useSplitJSON": true,
    "workbench.colorCustomizations": {
        "editor.selectionBackground": "#135564",
        "editor.selectionHighlightBackground": "#135564",
        "terminal.foreground": "#9ccc9c",
        "terminal.selectionBackground": "#135564",
        "terminal.selectionHighlightBackground": "#135564"
    },
    "window.systemColorTheme": "auto",
    "window.autoDetectColorScheme": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.fontFamily": "JetBrains Mono, Consolas, 'Courier New', monospace",
    "editor.fontLigatures": true,
    "editor.letterSpacing": 0.4,
    "editor.tabSize": 2,
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.inlineSuggest.enabled": true,
    "editor.accessibilitySupport": "off",
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit",
        "quickfix.biome": "explicit"
    },
    "[python]": {
        "editor.defaultFormatter": "ms-python.python",
        "editor.formatOnType": true
    },
    "[javascript]": {
        "editor.defaultFormatter": "biomejs.biome"
    },
    "[typescript]": {
        "editor.defaultFormatter": "biomejs.biome"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "biomejs.biome"
    },
    "[dockercompose]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "advanced",
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[github-actions-workflow]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "notebook.cellToolbarLocation": {
        "default": "right",
        "jupyter-notebook": "left"
    },
    "terminal.integrated.gpuAcceleration": "off",
    "terminal.integrated.fontFamily": "JetBrains Mono",
    "terminal.integrated.fontSize": 13,
    "terminal.integrated.lineHeight": 1.3,
    "terminal.integrated.scrollback": 10000,
    "terminal.integrated.env.osx": {
        "CLAUDE_CONFIG_DIR": "$HOME/.cch"
    },
    "git.autofetch": true,
    "git.confirmSync": false,
    "diffEditor.ignoreTrimWhitespace": true,
    "gitlens.advanced.messages": {
        "suppressGitMissingWarning": true
    },
    "files.autoSave": "afterDelay",
    "python.analysis.extraPaths": ["app"],
    "python.analysis.typeCheckingMode": "basic",
    "python.languageServer": "None",
    "biome.lspBin": "./client/node_modules/.bin/biome",
    "eslint.enable": false,
    "js/ts.updateImportsOnFileMove.enabled": "always",
    "typescript.updateImportsOnFileMove.enabled": "always",
    "security.workspace.trust.untrustedFiles": "open",
    "console-ninja.featureSet": "Community",
    "geminicodeassist.displayInlineContextHint": false,
    "explorer.confirmDelete": false,
    "bracket-pair-colorizer-2.depreciation-notice": false,
    "json.schemaDownload.trustedDomains": {
        "https://schemastore.azurewebsites.net/": true,
        "https://raw.githubusercontent.com/": true,
        "https://www.schemastore.org/": true,
        "https://json-schema.org/": true,
        "https://biomejs.dev": true
    },
    "chat.disableAIFeatures": true,
    "workbench.navigationControl.enabled": false,
    "window.commandCenter": false
}
